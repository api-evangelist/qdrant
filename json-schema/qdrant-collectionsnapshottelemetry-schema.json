{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/CollectionSnapshotTelemetry",
  "title": "CollectionSnapshotTelemetry",
  "type": "object",
  "required": [
    "id"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "running_snapshots": {
      "type": "integer",
      "format": "uint",
      "minimum": 0,
      "nullable": true
    },
    "running_snapshot_recovery": {
      "type": "integer",
      "format": "uint",
      "minimum": 0,
      "nullable": true
    },
    "total_snapshot_creations": {
      "type": "integer",
      "format": "uint",
      "minimum": 0,
      "nullable": true
    }
  }
}