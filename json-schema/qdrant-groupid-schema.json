{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/GroupId",
  "title": "GroupId",
  "description": "Value of the group_by key, shared across all the hits in the group",
  "anyOf": [
    {
      "type": "string"
    },
    {
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    {
      "type": "integer",
      "format": "int64"
    }
  ]
}