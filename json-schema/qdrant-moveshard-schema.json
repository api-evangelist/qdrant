{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/MoveShard",
  "title": "MoveShard",
  "type": "object",
  "required": [
    "from_peer_id",
    "shard_id",
    "to_peer_id"
  ],
  "properties": {
    "shard_id": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "to_peer_id": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    "from_peer_id": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    "method": {
      "description": "Method for transferring the shard from one node to another",
      "anyOf": [
        {
          "$ref": "#/components/schemas/ShardTransferMethod"
        },
        {
          "nullable": true
        }
      ]
    }
  }
}