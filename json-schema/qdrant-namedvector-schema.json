{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/NamedVector",
  "title": "NamedVector",
  "description": "Dense vector data with name",
  "type": "object",
  "required": [
    "name",
    "vector"
  ],
  "properties": {
    "name": {
      "description": "Name of vector data",
      "type": "string"
    },
    "vector": {
      "description": "Vector data",
      "type": "array",
      "items": {
        "type": "number",
        "format": "float"
      }
    }
  }
}