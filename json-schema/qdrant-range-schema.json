{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Range",
  "title": "Range",
  "description": "Range filter request",
  "type": "object",
  "properties": {
    "lt": {
      "description": "point.key < range.lt",
      "type": "number",
      "format": "double",
      "nullable": true
    },
    "gt": {
      "description": "point.key > range.gt",
      "type": "number",
      "format": "double",
      "nullable": true
    },
    "gte": {
      "description": "point.key >= range.gte",
      "type": "number",
      "format": "double",
      "nullable": true
    },
    "lte": {
      "description": "point.key <= range.lte",
      "type": "number",
      "format": "double",
      "nullable": true
    }
  }
}